declare export const CANNOT_FIX: 'CANNOT_FIX';

declare export const createSpecificTransformer: (
  property: string,
) => (
  rawValue: number | string,
  allowImportant?: boolean,
  _preferInline?: boolean,
) => $ReadOnlyArray<$ReadOnly<[string, number | string]>>;

declare export const createDirectionalTransformer: (
  baseProperty: string,
  blockSuffix: string,
  inlineSuffix: string,
) => (
  rawValue: number | string,
  allowImportant?: boolean,
  preferInline?: boolean,
) => [string, string | number][];

declare export const createBlockInlineTransformer: (
  baseProperty: string,
  suffix: string,
) => (
  rawValue: number | string,
  allowImportant?: boolean,
) => [string, string | number][];

declare export function splitSpecificShorthands(
  property: string,
  value: string,
  allowImportant?: boolean,
  isNumber?: boolean,
  _preferInline?: boolean,
): $ReadOnlyArray<$ReadOnly<[string, number | string]>>;

declare export function splitDirectionalShorthands(
  str: number | string,
  allowImportant?: boolean,
): $ReadOnlyArray<number | string>;
