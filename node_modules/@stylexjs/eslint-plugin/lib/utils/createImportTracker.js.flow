import type { ImportDeclaration } from '../../flow_modules/estree';

export type ValidImportSource =
  | string
  | {
      from: string,
      as: string,
    };

type ImportTracker = {
  ImportDeclaration: (node: ImportDeclaration) => void,
  isStylexDefaultImport: (name: string) => boolean,
  isStylexNamedImport: (importName: string, name: string) => boolean,
  clear: () => void,
};

declare export default function createImportTracker(
  importsToLookFor: Array<ValidImportSource>,
): ImportTracker;
