import type { Expression, Pattern, Property } from '../../flow_modules/estree';
import type { Rule } from '../../flow_modules/eslint';
import isString from '../rules/isString';
export type RuleResponse = void | {
  message: string,
  distance?: number,
  suggest?: {
    fix: Rule.ReportFixer,
    desc: string,
  },
};
export type RuleCheck = (
  node: $ReadOnly<Expression | Pattern>,
  variables?: Variables,
  prop?: $ReadOnly<Property>,
) => RuleResponse;

export type Variables = $ReadOnlyMap<string, Expression | 'ARG'>;

declare const isStringOrNumber: RuleCheck;

declare const isLength: RuleCheck;

