import { Rule } from '../flow_modules/eslint';

declare const stylexEnforceExtension: {
  meta: {
    type: 'problem',
    docs: {
      description: 'Ensure that files exporting `defineVars` or `defineConsts` variables end with a configurable extension, defaulting to `.stylex`, with an option to enforce an additional `.const` suffix for `defineConsts`. Mixed exports are not allowed unless explicitly configured for legacy support.',
      category: 'Possible Errors',
      recommended: false,
    },
    schema: $FlowFixMe,
  },
  create(context: Rule.RuleContext): { ... },
};

declare export default typeof stylexEnforceExtension;
